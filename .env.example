# ===================================================
# Smart Attendance Web - Environment Variables
# ===================================================
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# Copy this to .env.local and fill in actual values
# ===================================================

# Face AI API URL (Render.com)
# ใส่ URL ที่ได้จาก Render หลัง deploy เสร็จ
VITE_API_URL=https://YOUR_RENDER_APP_NAME.onrender.com/api/verify_face

# Attendance DB API URL (Render.com Node.js server)
VITE_ATTENDANCE_API_URL=https://YOUR_DB_APP_NAME.onrender.com

# ตัวอย่าง (หลัง deploy แล้ว):
# VITE_API_URL=https://titan-auth-api.onrender.com/api/verify_face
# VITE_ATTENDANCE_API_URL=https://new-data2.onrender.com
